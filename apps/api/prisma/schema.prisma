  completedAt  DateTime?

  @@index([tenantId, status])
  @@map("sftp_import_jobs")
}

// ─────────────────────────────── CFG-006: Roster & geofencing ───────────────────────────────

model RosterShift {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  shiftId    String
  date       DateTime
  location   String?
  createdAt  DateTime @default(now())

  @@unique([tenantId, employeeId, date])
  @@map("roster_shifts")
}

model GeofenceZone {
  id        String  @id @default(uuid())
  tenantId  String
  name      String
  latitude  Float
  longitude Float
  radiusM   Int     @default(200)
  isActive  Boolean @default(true)

  @@unique([tenantId, name])
  @@map("geofence_zones")
}

// ─────────────────────────────── Sheet 04: Workflow versions ───────────────────────────────

model WorkflowVersion {
  id          String   @id @default(uuid())
  tenantId    String
  workflowId  String
  workflow    ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  version     Int
  definition  Json
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([workflowId, version])
  @@map("workflow_versions")
}

// ─────────────────────────────── Remaining feature modules ───────────────────────────────

model JobFamily {
  id       String @id @default(uuid())
  tenantId String
  code     String
  name     String
  @@unique([tenantId, code])
  @@map("job_families")
}

model OrgPosition {
  id       String @id @default(uuid())
  tenantId String
  code     String
  title    String
  familyId String?
  isActive Boolean @default(true)
  @@unique([tenantId, code])
  @@map("org_positions")
}

model BgvPackage {
  id          String @id @default(uuid())
  tenantId    String
  code        String
  name        String
  checks      Json
  isActive    Boolean @default(true)
  @@unique([tenantId, code])
  @@map("bgv_packages")
}

model JobTeamMember {
  id     String @id @default(uuid())
  tenantId String
  jobId  String
  userId String
  role   String
  @@unique([jobId, userId, role])
  @@map("job_team_members")
}

model ApprovalDelegation {
  id           String   @id @default(uuid())
  tenantId     String
  delegatorId  String
  delegateId   String
  startsAt     DateTime
  endsAt       DateTime?
  isActive     Boolean  @default(true)
  @@map("approval_delegations")
}

model WorkflowRule {
  id       String @id @default(uuid())
  tenantId String
  ruleType String
  name     String
  definition Json
  isActive Boolean @default(true)
  @@map("workflow_rules")
}

model RatingScale {
  id       String @id @default(uuid())
  tenantId String
  name     String
  levels   Json
  @@unique([tenantId, name])
  @@map("rating_scales")
}

model PerformanceCheckIn {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  managerId  String?
  notes      String
  mood       Int?
  createdAt  DateTime @default(now())
  @@map("performance_checkins")
}

model CalibrationSession {
  id       String @id @default(uuid())
  tenantId String
  cycleId  String?
  name     String
  status   String @default("DRAFT")
  ratings  Json?
  @@map("calibration_sessions")
}

model CountryConfig {
  id        String @id @default(uuid())
  tenantId  String
  country   String
  settings  Json
  @@unique([tenantId, country])
  @@map("country_configs")
}

model DocumentRepositoryItem {
  id       String @id @default(uuid())
  tenantId String
  title    String
  category String
  fileId   String?
  tags     String[]
  @@map("document_repository")
}

model ScheduledJobDef {
  id       String @id @default(uuid())
  tenantId String
  name     String
  cron     String
  jobType  String
  config   Json?
  isActive Boolean @default(true)
  @@map("scheduled_job_defs")
}
