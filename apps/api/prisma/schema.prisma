// ─────────────────────────────── Exit process ───────────────────────────────

enum ResignationStatus {
  SUBMITTED
  APPROVAL
  ACCEPTED
  CLEARANCE
  FNF
  RELEASED
  WITHDRAWN
  REJECTED
}

model Resignation {
  id                 String            @id @default(uuid())
  tenantId           String
  employeeId         String            @unique
  employee           Employee          @relation(fields: [employeeId], references: [id])
  reason             String?
  submittedAt        DateTime          @default(now())
  requestedLastDay   DateTime?
  agreedLastDay      DateTime?
  status             ResignationStatus @default(SUBMITTED)
  releaseLetterFileId String?

  clearances ExitClearance[]
  settlement FullFinalSettlement?

  @@map("resignations")
}

enum ClearanceStatus {
  PENDING
  IN_PROGRESS
  SIGNED_OFF
  REJECTED
}

// Departmental NOC — head signs off, may delegate to a subordinate.
model ExitClearance {
  id            String          @id @default(uuid())
  tenantId      String
  resignationId String
  resignation   Resignation     @relation(fields: [resignationId], references: [id], onDelete: Cascade)
  departmentId  String
  department    Department      @relation(fields: [departmentId], references: [id])
  assigneeId    String? // head or delegated subordinate (employee id)
  status        ClearanceStatus @default(PENDING)
  remarks       String?
  signedOffBy   String?
  signedOffAt   DateTime?

  @@unique([resignationId, departmentId])
  @@map("exit_clearances")
}

model FullFinalSettlement {
  id            String      @id @default(uuid())
  tenantId      String
  resignationId String      @unique
  resignation   Resignation @relation(fields: [resignationId], references: [id])
  // earnings, deductions, notice recovery, leave encashment…
  breakup     Json
  netPayable  Decimal
  settledAt   DateTime?
  letterFileId String? // final letters issued on F&F completion
  createdAt   DateTime    @default(now())

  @@map("fnf_settlements")
}

// ─────────────────────────────── Approval engine (cross-cutting) ───────────────────────────────

enum ApprovalEntity {
  ONBOARDING
  RESIGNATION
  TIMESHEET
  OFFER
  ALLOCATION
  EXIT_CLEARANCE
  OTHER
}

model ApprovalWorkflow {
  id         String         @id @default(uuid())
  tenantId   String
  entityType ApprovalEntity
  name       String
  isActive   Boolean        @default(true)

  steps    ApprovalStep[]
  requests ApprovalRequest[]
  versions WorkflowVersion[]

  @@unique([tenantId, entityType, name])
  @@map("approval_workflows")
}

model ApprovalStep {
  id         String           @id @default(uuid())
  workflowId String
  workflow   ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepOrder  Int
  // approver resolution: by designation, department head, reporting manager, or named user
  approverType  String // DESIGNATION | DEPARTMENT_HEAD | REPORTING_MANAGER | USER
  approverValue String? // designation name / user id

  @@unique([workflowId, stepOrder])
  @@map("approval_steps")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model ApprovalRequest {
  id          String           @id @default(uuid())
  tenantId    String
  workflowId  String
  workflow    ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  entityType  ApprovalEntity
  entityId    String // id of the onboarding case / resignation / timesheet…
  currentStep Int              @default(1)
  status      RequestStatus    @default(PENDING)
  createdAt   DateTime         @default(now())

  actions ApprovalAction[]

  @@index([tenantId, entityType, entityId])
  @@map("approval_requests")
}

model ApprovalAction {
  id        String          @id @default(uuid())
  requestId String
  request   ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepOrder Int
  actorId   String // user id
  action    String // APPROVED | REJECTED | DELEGATED
  comment   String?
  createdAt DateTime        @default(now())

  @@map("approval_actions")
}

