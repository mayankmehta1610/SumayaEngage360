# PostgreSQL connection.
# IMPORTANT: keep `?schema=engage360` — all tables for this project live in the
# project-specific "engage360" Postgres schema so the database can be shared
# with other projects. When moving to a dedicated database later, keep the same
# schema param and the tables deploy identically.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/engage360?schema=engage360"

# Auth
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="8h"

# Server
PORT=3000

# Public URLs used in emails/links
APP_BASE_URL="https://engage360-web.onrender.com"
API_BASE_URL="https://engage360-api-qhnr.onrender.com"

# S3-compatible object storage (optional — falls back to local ./uploads).
# Works with AWS S3, Cloudflare R2, Backblaze B2 etc. via S3_ENDPOINT.
# S3_BUCKET=engage360-files
# S3_REGION=auto
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...

# SMTP email delivery (optional — logs instead of sending when unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# MAIL_FROM="Engage360 <no-reply@yourdomain.com>"

# LLM resume parsing (optional — raw CV is still stored when unset)
# ANTHROPIC_API_KEY=sk-ant-...
# RESUME_PARSER_MODEL=claude-opus-4-8
